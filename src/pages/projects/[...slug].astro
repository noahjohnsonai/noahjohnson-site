---
import { getCollection, render } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';
import SkillsShowcase from '../../components/SkillsShowcase.astro';

export async function getStaticPaths() {
	const projects = await getCollection('projects', ({ data }) => !data.draft);
	return projects.map((entry) => ({
		params: { slug: entry.id },
		props: { entry },
	}));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const skills = entry.data.skills ?? [];
---

<PostLayout
	title={entry.data.title}
	description={entry.data.description}
	tags={entry.data.tags}
	collectionLabel="Projects"
	collectionHref="/"
	rawMarkdown={entry.body ?? ''}
	rawFilename={`${entry.id}.md`}
>
	{skills.length > 0 && (
		<section slot="belowHeader" class="mb-6" aria-labelledby="project-skills-heading">
			<h2 id="project-skills-heading" class="sr-only">Built with</h2>
			<SkillsShowcase rows={[{ direction: 'left', skills }]} duration={25} />
		</section>
	)}
	<div class="project-content">
		<Content />
	</div>
</PostLayout>
