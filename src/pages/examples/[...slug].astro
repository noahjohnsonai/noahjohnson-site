---
import { getCollection, render } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';

export async function getStaticPaths() {
	const examples = await getCollection('examples');
	return examples.map((entry) => ({
		params: { slug: entry.id },
		props: { entry },
	}));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const downloadHref = `/examples/${entry.id}.md`;
---

<PostLayout
	title={entry.data.title}
	description={entry.data.description}
	collectionLabel="Examples"
	collectionHref="/"
	rawMarkdown={entry.body ?? ''}
	rawFilename={`${entry.id}.md`}
>
	<aside slot="belowHeader" class="mb-6 flex flex-wrap items-center gap-3 text-sm text-fg-muted">
		<span>Take-home artifact.</span>
		<a
			href={downloadHref}
			download={`${entry.id}.md`}
			class="inline-flex items-center gap-1.5 px-3 py-1 rounded-md border border-border-soft hover:border-accent/60 text-accent no-underline transition-colors"
		>
			<svg width="13" height="13" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
				<path d="M7 1v9M3 7l4 4 4-4M2 13h10" />
			</svg>
			<span>Download .md</span>
		</a>
	</aside>
	<div class="example-content">
		<Content />
	</div>
</PostLayout>
