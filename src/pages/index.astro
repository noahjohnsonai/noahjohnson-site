---
import Layout from '../layouts/Layout.astro';
import WelcomeHero from '../components/WelcomeHero.astro';
import SessionList from '../components/SessionList.astro';
import { getSortedPosts, getSortedProjects } from '../lib/data.ts';

const posts = (await getSortedPosts()).slice(0, 6);
const projects = (await getSortedProjects()).slice(0, 4);
---

<Layout
	breadcrumbs={[{ label: 'noahjohnson.ai' }]}
>
	<WelcomeHero />
	<SessionList heading="Recent Sessions" entries={posts} collection="posts" />
	{projects.length > 0 && (
		<div class="mt-8">
			<SessionList heading="Projects" entries={projects} collection="projects" />
		</div>
	)}
</Layout>
