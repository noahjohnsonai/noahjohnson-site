---
import { getEntry, render } from 'astro:content';
import PostLayout from '../layouts/PostLayout.astro';
import SkillsShowcase from '../components/SkillsShowcase.astro';
import TagCloud from '../components/TagCloud.astro';

const entry = await getEntry('about', 'about');
if (!entry) {
	throw new Error('Missing about.md content at src/content/about/about.md');
}
const { Content } = await render(entry);

// Union of every slug used across project-page marquees, organized into
// 5 rows that alternate direction. Keep this in sync when new tech lands
// in a project's `skills` frontmatter.
const certifications = [
	{
		title: 'Introduction to Model Context Protocol',
		issuer: 'Anthropic',
		year: 2026,
		credentialId: '5piyyitfk482',
		url: 'https://verify.skilljar.com/c/5piyyitfk482',
	},
	{
		title: 'Building with the Claude API',
		issuer: 'Anthropic',
		year: 2026,
		credentialId: 'txk3kej995q8',
		url: 'https://verify.skilljar.com/c/txk3kej995q8',
	},
	{
		title: 'Claude Code in Action',
		issuer: 'Anthropic',
		year: 2026,
		credentialId: '6rs9hdd84mda',
		url: 'https://verify.skilljar.com/c/6rs9hdd84mda',
	},
	{
		title: 'Introduction to agent skills',
		issuer: 'Anthropic',
		year: 2026,
		credentialId: 's8x3ffghuttq',
		url: 'https://verify.skilljar.com/c/s8x3ffghuttq',
	},
];

const skillRows = [
	{
		direction: 'left' as const,
		skills: ['astro', 'nextjs', 'react', 'typescript', 'javascript', 'html'],
	},
	{
		direction: 'right' as const,
		skills: ['css', 'tailwindcss', 'sass', 'threejs', 'vite', 'vitest'],
	},
	{
		direction: 'left' as const,
		skills: ['claude-code', 'nodejs', 'bun', 'supabase', 'postgres', 'godot'],
	},
	{
		direction: 'right' as const,
		skills: ['vercel', 'docker', 'sentry', 'biome', 'github', 'git'],
	},
	{
		direction: 'left' as const,
		skills: ['vscode', 'bash', 'linux', 'pnpm', 'regex', 'markdown'],
	},
];
---

<PostLayout
	title={entry.data.title ?? 'About'}
	description={entry.data.description}
	collectionLabel="About"
	collectionHref="/about/"
	rawMarkdown={entry.body ?? ''}
	rawFilename="about.md"
	showProgress={false}
	minimalHeader
>
	<Content />
	<section slot="after" class="mt-10" aria-labelledby="certifications-heading">
		<h2 id="certifications-heading" class="text-xl font-semibold tracking-tight text-fg m-0 mb-3">Certifications</h2>
		<ul class="list-none p-0 m-0 grid grid-cols-1 sm:grid-cols-2 gap-3">
			{certifications.map((cert) => (
				<li>
					<a
						href={cert.url}
						target="_blank"
						rel="noopener"
						aria-label={`View credential for ${cert.title}`}
						class="block no-underline border border-border-soft rounded-xl p-4 bg-bg-elevated hover:bg-surface transition-colors h-full"
					>
						<span class="flex items-center gap-2 mb-3 text-fg">
							<svg fill="currentColor" fill-rule="evenodd" viewBox="0 0 182 24" xmlns="http://www.w3.org/2000/svg" aria-label="Anthropic" class="h-3 w-auto"><path d="M38.247 15.874L29.553 2.338H24.86v19.337h4.002V8.139l8.694 13.536h4.693V2.338h-4.003v13.536zm7.313-9.807h6.487v15.608h4.14V6.067h6.487v-3.73H45.56v3.73zm33.686 3.978h-9.109V2.338h-4.14v19.337h4.14v-7.9h9.109v7.9h4.14V2.338h-4.14v7.707zm13.39-3.978h5.108c2.043 0 3.12.746 3.12 2.155 0 1.408-1.077 2.154-3.12 2.154h-5.107v-4.31zm12.37 2.155c0-3.647-2.679-5.884-7.068-5.884h-9.443v19.337h4.142v-7.57h4.61l4.142 7.57h4.583l-4.586-8.146c2.302-.885 3.62-2.75 3.62-5.307zm12.686 9.91c-3.257 0-5.244-2.32-5.244-6.104 0-3.84 1.987-6.16 5.244-6.16 3.23 0 5.189 2.32 5.189 6.16 0 3.784-1.96 6.105-5.189 6.105zm0-16.132c-5.575 0-9.522 4.144-9.522 10.028 0 5.828 3.947 9.972 9.522 9.972 5.547 0 9.466-4.144 9.466-9.972C127.158 6.144 123.24 2 117.692 2zm22.59 8.929h-5.109V6.067h5.11c2.043 0 3.12.829 3.12 2.43 0 1.603-1.077 2.432-3.12 2.432zm.194-8.591h-9.445v19.337h4.142v-7.017h5.303c4.39 0 7.07-2.32 7.07-6.16 0-3.84-2.68-6.16-7.07-6.16zm35.108 12.839c-.718 1.878-2.153 2.956-4.113 2.956-3.257 0-5.244-2.32-5.244-6.105 0-3.84 1.987-6.16 5.244-6.16 1.96 0 3.395 1.077 4.113 2.955h4.388C178.896 4.68 175.667 2 171.472 2c-5.576 0-9.523 4.144-9.523 10.028 0 5.828 3.947 9.972 9.522 9.972 4.223 0 7.453-2.707 8.529-6.823h-4.416zm-26.39-12.84l7.705 19.338h4.225L153.42 2.338h-4.225zM9.277 14.024l2.636-6.796 2.637 6.796H9.276zm.428-11.685L2 21.675h4.307l1.576-4.06h8.06l1.575 4.06h4.307L14.121 2.338H9.704z"></path></svg>
							<img src="/icons/claude.svg" alt="" width="18" height="18" />
						</span>
						<span class="block text-fg font-semibold text-[15px] leading-snug mb-2">{cert.title}</span>
						<span class="block text-fg-muted text-[12px]">Anthropic Education · Issued May 2026</span>
						<span class="mt-3 flex items-baseline justify-between gap-2">
							<span class="text-fg-dim text-[11px] font-mono truncate">{cert.credentialId}</span>
							<span class="text-[12px] text-accent whitespace-nowrap">View credential ↗</span>
						</span>
					</a>
				</li>
			))}
		</ul>
	</section>
	<section slot="after" class="mt-10" aria-labelledby="skills-heading">
		<h2 id="skills-heading" class="text-xl font-semibold tracking-tight text-fg m-0 mb-1">Skills</h2>
		<SkillsShowcase rows={skillRows} />
	</section>
	<section slot="after" class="mt-10" aria-labelledby="tags-heading">
		<h2 id="tags-heading" class="text-xl font-semibold tracking-tight text-fg m-0 mb-4">Tags</h2>
		<TagCloud />
	</section>
</PostLayout>
