---
import { getCollection, render } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';
import { assertCaseStudyInvariants, getReferencedExamples } from '../../lib/data.ts';

export async function getStaticPaths() {
	await assertCaseStudyInvariants();
	const studies = await getCollection('caseStudies', ({ data }) => !data.draft);
	return studies.map((entry) => ({
		params: { slug: entry.id },
		props: { entry },
	}));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const examples = await getReferencedExamples(entry.body ?? '');
---

<PostLayout
	title={entry.data.title}
	description={entry.data.description}
	pubDate={entry.data.pubDate}
	updatedDate={entry.data.updatedDate}
	tags={entry.data.tags}
	collectionLabel="Case Studies"
	collectionHref="/case-studies/"
	rawMarkdown={entry.body ?? ''}
	rawFilename={`${entry.id}.md`}
	examples={examples}
	cover={entry.data.cover}
	coverAlt={entry.data.coverAlt}
>
	<div class="project-content">
		<Content />
	</div>
	<aside slot="after" class="mt-10 pt-6 border-t border-border-soft text-sm text-fg-muted">
		Paired with project:
		{' '}
		<a
			href={`/projects/${entry.data.project}/`}
			class="text-accent hover:underline"
		>
			{entry.data.project}
		</a>
	</aside>
</PostLayout>
