---
import { getCollection, render } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';
import { assertCaseStudyInvariants, getReferencedExamples } from '../../lib/data.ts';

export async function getStaticPaths() {
	await assertCaseStudyInvariants();
	const studies = await getCollection('caseStudies', ({ data }) => !data.draft);
	return studies.map((entry) => ({
		params: { slug: entry.id },
		props: { entry },
	}));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const examples = await getReferencedExamples(entry.body ?? '');
// Fetch the paired project so the chip can show its title (not just slug).
// assertCaseStudyInvariants above guarantees this lookup succeeds.
const allProjects = await getCollection('projects');
const pairedProject = allProjects.find((p) => p.id === entry.data.project);
---

<PostLayout
	title={entry.data.title}
	description={entry.data.description}
	pubDate={entry.data.pubDate}
	updatedDate={entry.data.updatedDate}
	tags={entry.data.tags}
	collectionLabel="Case Studies"
	collectionHref="/case-studies/"
	rawMarkdown={entry.body ?? ''}
	rawFilename={`${entry.id}.md`}
	examples={examples}
	cover={entry.data.cover}
	coverAlt={entry.data.coverAlt}
>
	{pairedProject && (
		<aside slot="belowHeader" class="mb-6">
			<a
				href={`/projects/${pairedProject.id}/`}
				class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-accent/40 bg-accent/5 text-accent text-[13px] font-medium no-underline hover:bg-accent/10 hover:border-accent/60 transition-colors"
			>
				<svg width="13" height="13" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
					<path d="M2 4a1 1 0 0 1 1-1h3l2 2h3a1 1 0 0 1 1 1v5a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V4Z" />
				</svg>
				<span>Paired with project: {pairedProject.data.title}</span>
			</a>
		</aside>
	)}
	<div class="project-content">
		<Content />
	</div>
</PostLayout>
