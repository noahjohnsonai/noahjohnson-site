---
import BaseLayout from './BaseLayout.astro';
import Sidebar from '../components/Sidebar.astro';
import Topbar from '../components/Topbar.astro';
import RightPanel from '../components/RightPanel.astro';
import SearchBar from '../components/SearchBar.astro';
import SearchOverlay from '../components/SearchOverlay.astro';
import Mascot from '../components/Mascot.astro';
import { getSortedPosts, getSortedProjects } from '../lib/data.ts';

interface Crumb {
	label: string;
	href?: string;
}
interface Props {
	title?: string;
	description?: string;
	image?: string;
	type?: 'website' | 'article';
	breadcrumbs: Crumb[];
	rawMarkdown?: string;
	rawFilename?: string;
}
const {
	title,
	description,
	image,
	type,
	breadcrumbs,
	rawMarkdown,
	rawFilename,
} = Astro.props;

// Recent items shown in the search overlay's default empty state.
const recentPosts = (await getSortedPosts()).slice(0, 4);
const recentProjects = (await getSortedProjects()).slice(0, 2);
const recentEntries = [...recentPosts, ...recentProjects];
---

<BaseLayout title={title} description={description} image={image} type={type}>
	<div class="shell flex h-dvh w-full overflow-hidden">
		<Sidebar />

		<div class="main-col flex flex-1 min-w-0 flex-col relative">
			<Topbar breadcrumbs={breadcrumbs} />
			<main
				id="main"
				class="flex-1 overflow-y-auto relative"
				transition:animate="fade"
			>
				<div class="content-col py-6">
					<slot />
				</div>
			</main>
			{/* Mascot anchored to the right edge of the centered content column */}
			<div
				class="mascot-anchor absolute inset-x-0 pointer-events-none"
				style="bottom: 6.25rem"
			>
				<div class="content-col relative">
					<Mascot
						size={72}
						class="mascot absolute right-0 bottom-0 opacity-90 pointer-events-none select-none z-10 sm:!w-[88px] sm:!h-[57px]"
					/>
				</div>
			</div>
			<SearchBar />
			<SearchOverlay recentEntries={recentEntries} />
		</div>

		<RightPanel rawMarkdown={rawMarkdown} filename={rawFilename} />
	</div>

	{/* Image lightbox overlay — populated by JS on click of any .prose img */}
	<div
		id="lightbox"
		class="fixed inset-0 z-[60] hidden items-center justify-center p-6 bg-bg/95"
		role="dialog"
		aria-modal="true"
		aria-hidden="true"
	>
		<button
			type="button"
			id="lightbox-close"
			class="absolute top-4 right-4 p-2 rounded-md text-fg-muted hover:bg-surface hover:text-fg bg-transparent border-0 cursor-pointer z-10"
			aria-label="Close image"
		>
			<svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
				<path d="M5 5l10 10M15 5l-10 10" />
			</svg>
		</button>
		<img
			id="lightbox-img"
			src=""
			alt=""
			class="max-w-[95vw] max-h-[90vh] rounded-lg border border-border-soft shadow-2xl object-contain"
		/>
	</div>

	<script>
		// ============================================================
		// Sidebar drawer (mobile) + right panel toggle + search overlay
		// + visited-post tracking. Vanilla JS, runs on every page nav.
		// ============================================================
		function init() {
			// --- Sidebar drawer ---
			const sidebar = document.getElementById('sidebar');
			const backdrop = document.getElementById('sidebar-backdrop');
			const sidebarToggle = document.getElementById('sidebar-toggle');
			const openSidebar = () => {
				if (!sidebar || !backdrop) return;
				sidebar.classList.remove('-translate-x-full');
				backdrop.classList.remove('opacity-0', 'pointer-events-none');
				backdrop.classList.add('opacity-100');
			};
			const closeSidebar = () => {
				if (!sidebar || !backdrop) return;
				sidebar.classList.add('-translate-x-full');
				backdrop.classList.add('opacity-0', 'pointer-events-none');
				backdrop.classList.remove('opacity-100');
			};
			// Use onclick (replaces handler) instead of addEventListener
			// to avoid double-binding on astro:page-load re-runs.
			if (sidebarToggle) (sidebarToggle as HTMLElement).onclick = openSidebar;
			if (backdrop) (backdrop as HTMLElement).onclick = closeSidebar;
			// Close drawer on nav (sidebar links)
			sidebar?.querySelectorAll('a').forEach((a) => {
				(a as HTMLElement).onclick = () => {
					if (window.innerWidth < 1024) closeSidebar();
				};
			});

			// --- Right panel toggle ---
			// Panel default: open if xl+ viewport, closed otherwise.
			// transition:persist preserves panel state across navigations.
			const rp = document.getElementById('rightpanel');
			const rpToggle = document.getElementById('rightpanel-toggle');
			const rpClose = document.getElementById('rightpanel-close');

			// --- Right panel content tracking ---
			// Each page that has markdown content includes a hidden
			// <script id="rp-page-data" type="application/json"> with
			// {filename, content}. We save it to localStorage so it
			// persists across navigations AND reloads. Pages without
			// data leave whatever was last loaded in place.
			const RP_CONTENT_KEY = 'nj:rp:content';
			const rpFilename = document.getElementById('rp-filename');
			const rpBody = document.getElementById('rp-body');

			const renderRPContent = (filename: string, content: string) => {
				if (!rpFilename || !rpBody) return;
				rpFilename.textContent = filename || 'content.md';
				const pre = document.createElement('pre');
				pre.className = 'm-0 p-4 text-[13px] leading-relaxed font-mono text-fg-muted whitespace-pre-wrap break-words';
				pre.textContent = content;
				rpBody.innerHTML = '';
				rpBody.appendChild(pre);
			};

			const pageData = document.getElementById('rp-page-data');
			if (pageData) {
				try {
					const parsed = JSON.parse(pageData.textContent || '{}');
					if (parsed && typeof parsed.content === 'string' && parsed.content.trim().length > 0) {
						localStorage.setItem(RP_CONTENT_KEY, JSON.stringify(parsed));
						renderRPContent(parsed.filename || 'content.md', parsed.content);
					}
				} catch {}
			} else {
				// No page data on this route — fall back to last loaded.
				const saved = localStorage.getItem(RP_CONTENT_KEY);
				if (saved) {
					try {
						const { filename, content } = JSON.parse(saved);
						if (content) renderRPContent(filename || 'content.md', content);
					} catch {}
				}
			}

			// --- Right panel: persisted open/closed + resizable width ---
			const RP_KEY = 'nj:rp';
			const RP_DEFAULT_WIDTH = 320;
			const RP_MIN = 240;
			const RP_MAX = Math.min(window.innerWidth * 0.7, 1200);

			const getRPState = () => {
				try {
					const s = JSON.parse(localStorage.getItem(RP_KEY) || '{}');
					return {
						open:
							typeof s.open === 'boolean'
								? s.open
								: window.matchMedia('(min-width: 1280px)').matches,
						width:
							typeof s.width === 'number' && s.width >= RP_MIN && s.width <= RP_MAX
								? s.width
								: RP_DEFAULT_WIDTH,
					};
				} catch {
					return { open: false, width: RP_DEFAULT_WIDTH };
				}
			};
			const saveRPState = (s: { open: boolean; width: number }) => {
				localStorage.setItem(RP_KEY, JSON.stringify(s));
			};
			const isDesktop = () => window.matchMedia('(min-width: 1024px)').matches;

			const applyRPState = (animate = true) => {
				if (!rp) return;
				const { open, width } = getRPState();
				rp.dataset.open = open ? '1' : '0';
				const rpEl = rp as HTMLElement;
				const inner = document.getElementById('rightpanel-content') as HTMLElement | null;
				const backdrop = document.getElementById('rightpanel-backdrop');

				if (isDesktop()) {
					if (!animate) rpEl.style.transition = 'none';
					rpEl.style.width = open ? `${width}px` : '0px';
					rpEl.style.borderLeftWidth = open ? '1px' : '0';
					if (inner) inner.style.width = `${width}px`;
					if (!animate) {
						void rpEl.offsetWidth;
						requestAnimationFrame(() => {
							rpEl.style.transition = '';
						});
					}
					// Hide mobile backdrop on desktop
					if (backdrop) {
						backdrop.classList.add('opacity-0', 'pointer-events-none');
						backdrop.classList.remove('opacity-100');
					}
				} else {
					// Mobile: CSS handles transform via [data-open="1"].
					// Clear any inline width that desktop set so CSS rules win.
					rpEl.style.width = '';
					rpEl.style.borderLeftWidth = '';
					if (inner) inner.style.width = '';
					if (backdrop) {
						if (open) {
							backdrop.classList.remove('opacity-0', 'pointer-events-none');
							backdrop.classList.add('opacity-100');
						} else {
							backdrop.classList.add('opacity-0', 'pointer-events-none');
							backdrop.classList.remove('opacity-100');
						}
					}
				}
			};

			if (rp && !rp.dataset.rpInit) {
				rp.dataset.rpInit = '1';
				applyRPState(false);
			}
			// Always re-apply on page nav (persistent across navigations)
			applyRPState(false);

			const toggleRP = () => {
				if (!rp) return;
				const s = getRPState();
				saveRPState({ ...s, open: !s.open });
				applyRPState(true);
			};
			if (rpToggle) (rpToggle as HTMLElement).onclick = toggleRP;
			if (rpClose) (rpClose as HTMLElement).onclick = toggleRP;
			// Click backdrop to close on mobile
			const rpBackdrop = document.getElementById('rightpanel-backdrop');
			if (rpBackdrop) (rpBackdrop as HTMLElement).onclick = toggleRP;

			// Re-apply state when viewport crosses lg breakpoint
			const mql = window.matchMedia('(min-width: 1024px)');
			if (!(mql as any).__nj_bound) {
				(mql as any).__nj_bound = true;
				mql.addEventListener('change', () => applyRPState(false));
			}

			// Resize handle
			const rpResize = document.getElementById('rightpanel-resize');
			if (rp && rpResize && !rpResize.dataset.rpResizeInit) {
				rpResize.dataset.rpResizeInit = '1';
				let dragging = false;
				let startX = 0;
				let startWidth = RP_DEFAULT_WIDTH;
				const rpEl = rp as HTMLElement;
				const resizeEl = rpResize as HTMLElement;

				resizeEl.addEventListener('pointerdown', (e) => {
					if (rp.dataset.open !== '1') return; // only resize when open
					dragging = true;
					startX = e.clientX;
					startWidth = parseInt(rpEl.style.width, 10) || RP_DEFAULT_WIDTH;
					resizeEl.setPointerCapture(e.pointerId);
					rpEl.style.transition = 'none';
					document.body.style.cursor = 'col-resize';
					document.body.style.userSelect = 'none';
				});
				resizeEl.addEventListener('pointermove', (e) => {
					if (!dragging) return;
					// Panel is on the right edge — drag left grows, drag right shrinks
					const dx = startX - e.clientX;
					let w = startWidth + dx;
					w = Math.max(RP_MIN, Math.min(RP_MAX, w));
					rpEl.style.width = `${w}px`;
					const inner = document.getElementById('rightpanel-content') as HTMLElement | null;
					if (inner) inner.style.width = `${w}px`;
				});
				const endDrag = (e: PointerEvent) => {
					if (!dragging) return;
					dragging = false;
					try { resizeEl.releasePointerCapture(e.pointerId); } catch {}
					rpEl.style.transition = '';
					document.body.style.cursor = '';
					document.body.style.userSelect = '';
					const w = parseInt(rpEl.style.width, 10) || RP_DEFAULT_WIDTH;
					saveRPState({ open: true, width: w });
				};
				resizeEl.addEventListener('pointerup', endDrag);
				resizeEl.addEventListener('pointercancel', endDrag);
			}

			// --- Search overlay ---
			const overlay = document.getElementById('search-overlay');
			const searchInput = document.getElementById('search-input') as HTMLInputElement | null;
			const searchResults = document.getElementById('search-results');
			const searchDefault = document.getElementById('search-default');
			const searchLive = document.getElementById('search-live');
			const triggers = [
				document.getElementById('search-trigger'),
				document.getElementById('searchbar-trigger'),
			];
			let pagefind: any = null;

			const showDefault = () => {
				if (searchDefault) searchDefault.classList.remove('hidden');
				if (searchLive) {
					searchLive.classList.add('hidden');
					searchLive.innerHTML = '';
				}
			};
			const showLive = (html: string) => {
				if (searchDefault) searchDefault.classList.add('hidden');
				if (searchLive) {
					searchLive.classList.remove('hidden');
					searchLive.innerHTML = html;
				}
			};

			const openSearch = async () => {
				if (!overlay) return;
				overlay.classList.remove('hidden');
				overlay.classList.add('flex');
				overlay.setAttribute('aria-hidden', 'false');
				showDefault();
				setTimeout(() => searchInput?.focus(), 50);

				if (!pagefind) {
					try {
						const pf = '/pagefind/' + 'pagefind.js';
						// @ts-ignore
						pagefind = await import(/* @vite-ignore */ pf);
						await pagefind.options({ baseUrl: '/' });
					} catch (e) {
						// Dev mode: pagefind not built yet. Search will just show defaults.
					}
				}
			};
			const closeSearch = () => {
				if (!overlay) return;
				overlay.classList.add('hidden');
				overlay.classList.remove('flex');
				overlay.setAttribute('aria-hidden', 'true');
				if (searchInput) searchInput.value = '';
				showDefault();
			};
			triggers.forEach((t) => { if (t) (t as HTMLElement).onclick = openSearch; });
			const searchCloseBtn = document.getElementById('search-close');
			if (searchCloseBtn) (searchCloseBtn as HTMLElement).onclick = closeSearch;
			if (overlay) (overlay as HTMLElement).onclick = (e) => {
				if (e.target === overlay) closeSearch();
			};

			// Search input → Pagefind (or fallback)
			let searchDebounce: number | undefined;
			if (searchInput) (searchInput as HTMLInputElement).oninput = () => {
				clearTimeout(searchDebounce);
				const q = searchInput.value.trim();
				if (!q) {
					showDefault();
					return;
				}
				if (!pagefind) {
					showLive('<p class="text-fg-dim text-sm p-4 text-center">Search is only available in the production build.</p>');
					return;
				}
				searchDebounce = window.setTimeout(async () => {
					const search = await pagefind.search(q);
					const items = await Promise.all(
						search.results.slice(0, 10).map((r: any) => r.data()),
					);
					if (items.length === 0) {
						showLive('<p class="text-fg-dim text-sm p-4 text-center">No results.</p>');
						return;
					}
					showLive(
						items
							.map(
								(d: any) => `
									<a href="${d.url}" class="block px-4 py-3 mx-1 rounded-md hover:bg-surface no-underline">
										<div class="text-fg font-medium text-sm">${d.meta?.title ?? d.url}</div>
										<div class="text-fg-muted text-xs mt-0.5 line-clamp-2">${d.excerpt}</div>
									</a>
								`,
							)
							.join(''),
					);
				}, 120);
			};

			// Keyboard shortcuts (document-level — track once)
			(document as any).__nj_keydown_bound = (document as any).__nj_keydown_bound || false;
			if (!(document as any).__nj_keydown_bound) {
				(document as any).__nj_keydown_bound = true;
					document.addEventListener('keydown', (e) => {
					if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'k') {
						e.preventDefault();
						// re-resolve overlay since it lives in DOM
						document.getElementById('searchbar-trigger')?.click();
					} else if (e.key === 'Escape') {
						// Close lightbox first if open, otherwise search overlay
						const lb = document.getElementById('lightbox');
						if (lb && !lb.classList.contains('hidden')) {
							document.getElementById('lightbox-close')?.click();
						} else {
							document.getElementById('search-close')?.click();
						}
					}
				});
			}

			// --- Image lightbox helpers (shared with prose-img listeners below) ---
			const lightbox = document.getElementById('lightbox');
			const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement | null;
			const lightboxClose = document.getElementById('lightbox-close');
			const openLightbox = (src: string, alt: string) => {
				if (!lightbox || !lightboxImg) return;
				lightboxImg.src = src;
				lightboxImg.alt = alt || '';
				lightbox.classList.remove('hidden');
				lightbox.classList.add('flex');
				lightbox.setAttribute('aria-hidden', 'false');
				document.body.style.overflow = 'hidden';
			};
			const closeLightbox = () => {
				if (!lightbox) return;
				lightbox.classList.add('hidden');
				lightbox.classList.remove('flex');
				lightbox.setAttribute('aria-hidden', 'true');
				document.body.style.overflow = '';
			};
			if (lightbox) (lightbox as HTMLElement).onclick = (e) => {
				if (e.target === lightbox || e.target === lightboxImg) closeLightbox();
			};
			if (lightboxClose) (lightboxClose as HTMLElement).onclick = closeLightbox;

			// --- Active sidebar item ---
			// Sidebar is transition:persist'd so the SSR-computed active class
			// from the previous page sticks. Re-apply on every page-load.
			(() => {
				const path = location.pathname.replace(/\/$/, '') || '/';
				const links = document.querySelectorAll('#sidebar a[data-slug]');
				links.forEach((a) => {
					const href = (a.getAttribute('href') || '').replace(/\/$/, '');
					const isActive = href === path;
					if (isActive) {
						a.classList.add('bg-surface', 'text-fg', 'font-medium');
						a.classList.remove('text-fg-muted');
						a.setAttribute('aria-current', 'page');
					} else {
						a.classList.remove('bg-surface', 'text-fg', 'font-medium');
						a.classList.add('text-fg-muted');
						a.removeAttribute('aria-current');
					}
				});
			})();

			// --- Image lightbox for prose images ---
			// Click any markdown image to expand it over the page. ESC or
			// click-outside closes.
			(() => {
				const imgs = document.querySelectorAll('.prose img');
				imgs.forEach((img) => {
					const el = img as HTMLImageElement;
					if (el.dataset.lbInit) return;
					el.dataset.lbInit = '1';
					el.style.cursor = 'pointer';
					el.addEventListener('click', () => openLightbox(el.src, el.alt));
				});
			})();

			// --- OS-aware keyboard shortcut label (⌘K vs Ctrl K) ---
			const ua = navigator.userAgent;
			const isMac = /Mac|iPhone|iPad|iPod/.test(ua) || /Mac/.test(navigator.platform);
			document.querySelectorAll('[data-kbd-modifier]').forEach((el) => {
				el.textContent = isMac ? '⌘K' : 'Ctrl K';
			});

			// --- Visited post tracking ---
			const KEY = 'nj:visited';
			const visited: Record<string, true> = JSON.parse(localStorage.getItem(KEY) ?? '{}');

			// Sync every dot in BOTH directions — show for unvisited, hide for visited.
			// Without the else branch, dots stayed lit on previously-unvisited slugs
			// even after the user navigated to them, until a full refresh.
			const syncDots = () => {
				const v: Record<string, true> = JSON.parse(localStorage.getItem(KEY) ?? '{}');
				document.querySelectorAll('[data-unvisited-dot]').forEach((el) => {
					const slug = el.getAttribute('data-unvisited-dot');
					(el as HTMLElement).style.opacity = slug && !v[slug] ? '1' : '0';
				});
			};
			syncDots();

			// Mark current slug as visited if we're on a post/project/about page
			const path = location.pathname.replace(/\/$/, '').replace(/^\//, '');
			if (path && (path.startsWith('posts/') || path.startsWith('projects/') || path === 'about')) {
				visited[path] = true;
				localStorage.setItem(KEY, JSON.stringify(visited));
			}

			// Real-time: when the user clicks a sidebar link to a post/project/about,
			// mark it visited and hide its dot immediately — don't wait for the
			// destination page's init() to fire after the view transition.
			document.querySelectorAll('aside#sidebar a[data-slug]').forEach((el) => {
				const a = el as HTMLAnchorElement;
				if (a.dataset.dotInit) return;
				a.dataset.dotInit = '1';
				a.addEventListener('click', () => {
					const slug = a.getAttribute('data-slug');
					if (!slug) return;
					const v: Record<string, true> = JSON.parse(localStorage.getItem(KEY) ?? '{}');
					v[slug] = true;
					localStorage.setItem(KEY, JSON.stringify(v));
					const dot = a.querySelector('[data-unvisited-dot]') as HTMLElement | null;
					if (dot) dot.style.opacity = '0';
				});
			});
		}

		init();
		document.addEventListener('astro:page-load', init);
	</script>
</BaseLayout>
