---
import BaseLayout from './BaseLayout.astro';
import Sidebar from '../components/Sidebar.astro';
import Topbar from '../components/Topbar.astro';
import RightPanel from '../components/RightPanel.astro';
import SearchBar from '../components/SearchBar.astro';
import SearchOverlay from '../components/SearchOverlay.astro';
import Mascot from '../components/Mascot.astro';
import { getSortedPosts, getSortedProjects } from '../lib/data.ts';

interface Crumb {
	label: string;
	href?: string;
}
interface Props {
	title?: string;
	description?: string;
	image?: string;
	type?: 'website' | 'article';
	breadcrumbs: Crumb[];
	rawMarkdown?: string;
	rawFilename?: string;
}
const {
	title,
	description,
	image,
	type,
	breadcrumbs,
	rawMarkdown,
	rawFilename,
} = Astro.props;

// Recent items shown in the search overlay's default empty state.
const recentPosts = (await getSortedPosts()).slice(0, 4);
const recentProjects = (await getSortedProjects()).slice(0, 2);
const recentEntries = [...recentPosts, ...recentProjects];
---

<BaseLayout title={title} description={description} image={image} type={type}>
	<div class="shell flex h-svh w-full overflow-hidden">
		<Sidebar />

		<div class="main-col flex flex-1 min-w-0 flex-col relative">
			<Topbar breadcrumbs={breadcrumbs} />
			<main
				id="main"
				class="flex-1 overflow-y-auto relative"
				transition:animate="fade"
			>
				<div class="max-w-3xl mx-auto px-4 sm:px-6 py-6">
					<slot />
				</div>
			</main>
			<Mascot
				size={72}
				class="mascot absolute bottom-20 right-4 sm:right-6 opacity-90 pointer-events-none select-none z-10"
			/>
			<SearchBar />
			<SearchOverlay recentEntries={recentEntries} />
		</div>

		<RightPanel rawMarkdown={rawMarkdown} filename={rawFilename} />
	</div>

	<script>
		// ============================================================
		// Sidebar drawer (mobile) + right panel toggle + search overlay
		// + visited-post tracking. Vanilla JS, runs on every page nav.
		// ============================================================
		function init() {
			// --- Sidebar drawer ---
			const sidebar = document.getElementById('sidebar');
			const backdrop = document.getElementById('sidebar-backdrop');
			const sidebarToggle = document.getElementById('sidebar-toggle');
			const openSidebar = () => {
				if (!sidebar || !backdrop) return;
				sidebar.classList.remove('-translate-x-full');
				backdrop.classList.remove('opacity-0', 'pointer-events-none');
				backdrop.classList.add('opacity-100');
			};
			const closeSidebar = () => {
				if (!sidebar || !backdrop) return;
				sidebar.classList.add('-translate-x-full');
				backdrop.classList.add('opacity-0', 'pointer-events-none');
				backdrop.classList.remove('opacity-100');
			};
			// Use onclick (replaces handler) instead of addEventListener
			// to avoid double-binding on astro:page-load re-runs.
			if (sidebarToggle) (sidebarToggle as HTMLElement).onclick = openSidebar;
			if (backdrop) (backdrop as HTMLElement).onclick = closeSidebar;
			// Close drawer on nav (sidebar links)
			sidebar?.querySelectorAll('a').forEach((a) => {
				(a as HTMLElement).onclick = () => {
					if (window.innerWidth < 1024) closeSidebar();
				};
			});

			// --- Right panel toggle ---
			// Panel default: open if xl+ viewport, closed otherwise.
			// transition:persist preserves panel state across navigations.
			const rp = document.getElementById('rightpanel');
			const rpToggle = document.getElementById('rightpanel-toggle');
			const rpClose = document.getElementById('rightpanel-close');

			// --- Right panel: persisted open/closed + resizable width ---
			const RP_KEY = 'nj:rp';
			const RP_DEFAULT_WIDTH = 320;
			const RP_MIN = 240;
			const RP_MAX = 600;

			const getRPState = () => {
				try {
					const s = JSON.parse(localStorage.getItem(RP_KEY) || '{}');
					return {
						open:
							typeof s.open === 'boolean'
								? s.open
								: window.matchMedia('(min-width: 1280px)').matches,
						width:
							typeof s.width === 'number' && s.width >= RP_MIN && s.width <= RP_MAX
								? s.width
								: RP_DEFAULT_WIDTH,
					};
				} catch {
					return { open: false, width: RP_DEFAULT_WIDTH };
				}
			};
			const saveRPState = (s: { open: boolean; width: number }) => {
				localStorage.setItem(RP_KEY, JSON.stringify(s));
			};
			const applyRPState = (animate = true) => {
				if (!rp) return;
				const { open, width } = getRPState();
				rp.dataset.open = open ? '1' : '0';
				const rpEl = rp as HTMLElement;
				const inner = document.getElementById('rightpanel-content') as HTMLElement | null;
				if (!animate) rpEl.style.transition = 'none';
				rpEl.style.width = open ? `${width}px` : '0px';
				rpEl.style.borderLeftWidth = open ? '1px' : '0';
				if (inner) inner.style.width = `${width}px`;
				if (!animate) {
					// Force reflow then re-enable transitions on next frame
					void rpEl.offsetWidth;
					requestAnimationFrame(() => {
						rpEl.style.transition = '';
					});
				}
			};

			if (rp && !rp.dataset.rpInit) {
				rp.dataset.rpInit = '1';
				applyRPState(false);
			}
			// Always re-apply on page nav (persistent across navigations)
			applyRPState(false);

			const toggleRP = () => {
				if (!rp) return;
				const s = getRPState();
				saveRPState({ ...s, open: !s.open });
				applyRPState(true);
			};
			if (rpToggle) (rpToggle as HTMLElement).onclick = toggleRP;
			if (rpClose) (rpClose as HTMLElement).onclick = toggleRP;

			// Resize handle
			const rpResize = document.getElementById('rightpanel-resize');
			if (rp && rpResize && !rpResize.dataset.rpResizeInit) {
				rpResize.dataset.rpResizeInit = '1';
				let dragging = false;
				let startX = 0;
				let startWidth = RP_DEFAULT_WIDTH;
				const rpEl = rp as HTMLElement;
				const resizeEl = rpResize as HTMLElement;

				resizeEl.addEventListener('pointerdown', (e) => {
					if (rp.dataset.open !== '1') return; // only resize when open
					dragging = true;
					startX = e.clientX;
					startWidth = parseInt(rpEl.style.width, 10) || RP_DEFAULT_WIDTH;
					resizeEl.setPointerCapture(e.pointerId);
					rpEl.style.transition = 'none';
					document.body.style.cursor = 'col-resize';
					document.body.style.userSelect = 'none';
				});
				resizeEl.addEventListener('pointermove', (e) => {
					if (!dragging) return;
					// Panel is on the right edge — drag left grows, drag right shrinks
					const dx = startX - e.clientX;
					let w = startWidth + dx;
					w = Math.max(RP_MIN, Math.min(RP_MAX, w));
					rpEl.style.width = `${w}px`;
					const inner = document.getElementById('rightpanel-content') as HTMLElement | null;
					if (inner) inner.style.width = `${w}px`;
				});
				const endDrag = (e: PointerEvent) => {
					if (!dragging) return;
					dragging = false;
					try { resizeEl.releasePointerCapture(e.pointerId); } catch {}
					rpEl.style.transition = '';
					document.body.style.cursor = '';
					document.body.style.userSelect = '';
					const w = parseInt(rpEl.style.width, 10) || RP_DEFAULT_WIDTH;
					saveRPState({ open: true, width: w });
				};
				resizeEl.addEventListener('pointerup', endDrag);
				resizeEl.addEventListener('pointercancel', endDrag);
			}

			// --- Search overlay ---
			const overlay = document.getElementById('search-overlay');
			const searchInput = document.getElementById('search-input') as HTMLInputElement | null;
			const searchResults = document.getElementById('search-results');
			const searchDefault = document.getElementById('search-default');
			const searchLive = document.getElementById('search-live');
			const triggers = [
				document.getElementById('search-trigger'),
				document.getElementById('searchbar-trigger'),
			];
			let pagefind: any = null;

			const showDefault = () => {
				if (searchDefault) searchDefault.classList.remove('hidden');
				if (searchLive) {
					searchLive.classList.add('hidden');
					searchLive.innerHTML = '';
				}
			};
			const showLive = (html: string) => {
				if (searchDefault) searchDefault.classList.add('hidden');
				if (searchLive) {
					searchLive.classList.remove('hidden');
					searchLive.innerHTML = html;
				}
			};

			const openSearch = async () => {
				if (!overlay) return;
				overlay.classList.remove('hidden');
				overlay.classList.add('flex');
				overlay.setAttribute('aria-hidden', 'false');
				showDefault();
				setTimeout(() => searchInput?.focus(), 50);

				if (!pagefind) {
					try {
						const pf = '/pagefind/' + 'pagefind.js';
						// @ts-ignore
						pagefind = await import(/* @vite-ignore */ pf);
						await pagefind.options({ baseUrl: '/' });
					} catch (e) {
						// Dev mode: pagefind not built yet. Search will just show defaults.
					}
				}
			};
			const closeSearch = () => {
				if (!overlay) return;
				overlay.classList.add('hidden');
				overlay.classList.remove('flex');
				overlay.setAttribute('aria-hidden', 'true');
				if (searchInput) searchInput.value = '';
				showDefault();
			};
			triggers.forEach((t) => { if (t) (t as HTMLElement).onclick = openSearch; });
			const searchCloseBtn = document.getElementById('search-close');
			if (searchCloseBtn) (searchCloseBtn as HTMLElement).onclick = closeSearch;
			if (overlay) (overlay as HTMLElement).onclick = (e) => {
				if (e.target === overlay) closeSearch();
			};

			// Search input → Pagefind (or fallback)
			let searchDebounce: number | undefined;
			if (searchInput) (searchInput as HTMLInputElement).oninput = () => {
				clearTimeout(searchDebounce);
				const q = searchInput.value.trim();
				if (!q) {
					showDefault();
					return;
				}
				if (!pagefind) {
					showLive('<p class="text-fg-dim text-sm p-4 text-center">Search is only available in the production build.</p>');
					return;
				}
				searchDebounce = window.setTimeout(async () => {
					const search = await pagefind.search(q);
					const items = await Promise.all(
						search.results.slice(0, 10).map((r: any) => r.data()),
					);
					if (items.length === 0) {
						showLive('<p class="text-fg-dim text-sm p-4 text-center">No results.</p>');
						return;
					}
					showLive(
						items
							.map(
								(d: any) => `
									<a href="${d.url}" class="block px-4 py-3 mx-1 rounded-md hover:bg-surface no-underline">
										<div class="text-fg font-medium text-sm">${d.meta?.title ?? d.url}</div>
										<div class="text-fg-muted text-xs mt-0.5 line-clamp-2">${d.excerpt}</div>
									</a>
								`,
							)
							.join(''),
					);
				}, 120);
			};

			// Keyboard shortcuts (document-level — track once)
			(document as any).__nj_keydown_bound = (document as any).__nj_keydown_bound || false;
			if (!(document as any).__nj_keydown_bound) {
				(document as any).__nj_keydown_bound = true;
					document.addEventListener('keydown', (e) => {
					if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'k') {
						e.preventDefault();
						// re-resolve overlay since it lives in DOM
						document.getElementById('searchbar-trigger')?.click();
					} else if (e.key === 'Escape') {
						document.getElementById('search-close')?.click();
					}
				});
			}

			// --- OS-aware keyboard shortcut label (⌘K vs Ctrl K) ---
			const ua = navigator.userAgent;
			const isMac = /Mac|iPhone|iPad|iPod/.test(ua) || /Mac/.test(navigator.platform);
			document.querySelectorAll('[data-kbd-modifier]').forEach((el) => {
				el.textContent = isMac ? '⌘K' : 'Ctrl K';
			});

			// --- Visited post tracking ---
			const KEY = 'nj:visited';
			const visited: Record<string, true> = JSON.parse(localStorage.getItem(KEY) ?? '{}');

			// Reveal orange dot for posts NOT in visited
			document.querySelectorAll('[data-unvisited-dot]').forEach((el) => {
				const slug = el.getAttribute('data-unvisited-dot');
				if (slug && !visited[slug]) {
					(el as HTMLElement).style.opacity = '1';
				}
			});

			// Mark current slug as visited if we're on a post/project/about page
			const path = location.pathname.replace(/\/$/, '').replace(/^\//, '');
			if (path && (path.startsWith('posts/') || path.startsWith('projects/') || path === 'about')) {
				visited[path] = true;
				localStorage.setItem(KEY, JSON.stringify(visited));
			}
		}

		init();
		document.addEventListener('astro:page-load', init);
	</script>
</BaseLayout>
