---
import Layout from './Layout.astro';
import Prose from '../components/Prose.astro';
import ScrollProgress from '../components/ScrollProgress.astro';
import { formatAbsoluteDate, formatMonthYear, readingTimeMinutes } from '../lib/data.ts';

interface ExampleRef {
	slug: string;
	title: string;
	filename: string;
	content: string;
	href: string;
}
interface Props {
	title: string;
	description?: string;
	pubDate?: Date;
	updatedDate?: Date;
	tags?: string[];
	collectionLabel: string; // "Posts" | "Projects" | "About"
	collectionHref: string;  // "/posts" | "/projects" | "/about"
	rawMarkdown: string;
	rawFilename: string;
	examples?: ExampleRef[];
	cover?: string;     // hero image path under public/
	coverAlt?: string;  // hero image alt text
	showProgress?: boolean; // render the scroll-progress tick timeline (default true)
	dateFormat?: 'full' | 'month-year'; // 'month-year' default — calendar-day on posts/case-studies is too precise
}
const {
	title,
	description,
	pubDate,
	updatedDate,
	tags = [],
	collectionLabel,
	collectionHref,
	rawMarkdown,
	rawFilename,
	examples = [],
	cover,
	coverAlt,
	showProgress = true,
	dateFormat = 'month-year',
} = Astro.props;

const readMinutes = rawMarkdown ? readingTimeMinutes(rawMarkdown) : 0;

const fmt = dateFormat === 'month-year' ? formatMonthYear : formatAbsoluteDate;

const breadcrumbs =
	collectionLabel === title
		? [{ label: 'noahjohnson.ai', href: '/' }, { label: title }]
		: [
				{ label: 'noahjohnson.ai', href: '/' },
				{ label: collectionLabel, href: collectionHref },
				{ label: title },
			];
---

<Layout
	title={title}
	description={description}
	type="article"
	breadcrumbs={breadcrumbs}
	rawMarkdown={rawMarkdown}
	rawFilename={rawFilename}
	examples={examples}
>
	{showProgress && <ScrollProgress />}
	<article>
		{cover && (
			<figure class="post-hero -mt-6 mb-8">
				<img
					src={cover}
					alt={coverAlt ?? ''}
					class="w-full h-auto rounded-lg border border-border-soft block"
					loading="eager"
					decoding="async"
				/>
			</figure>
		)}
		<header class="mb-8">
			<h1 class="text-2xl sm:text-3xl font-semibold tracking-tight text-fg leading-tight m-0 mb-2">
				{title}
			</h1>
			{description && (
				<p class="text-fg-muted text-base m-0 mb-4">{description}</p>
			)}
			<div class="flex flex-wrap items-center gap-x-3 gap-y-2 text-xs text-fg-dim">
				{pubDate && (
					<time datetime={pubDate.toISOString()}>
						{fmt(pubDate)}
					</time>
				)}
				{updatedDate && (
					<>
						<span>•</span>
						<span>updated <time datetime={updatedDate.toISOString()}>{fmt(updatedDate)}</time></span>
					</>
				)}
				{readMinutes > 0 && (
					<>
						<span>•</span>
						<span>{readMinutes} min read</span>
					</>
				)}
				{tags.length > 0 && (
					<>
						<span>•</span>
						<ul class="inline-flex flex-wrap gap-1.5 m-0 p-0 list-none">
							{tags.map((t) => (
								<li class="inline-block">
									<a
										href={`/tags/${encodeURIComponent(t)}/`}
										class="inline-block text-xs text-fg-muted hover:text-fg font-mono px-1.5 py-0.5 rounded bg-surface border border-border-soft hover:border-border no-underline transition-colors"
									>
										{t}
									</a>
								</li>
							))}
						</ul>
					</>
				)}
			</div>
		</header>
		<slot name="belowHeader" />
		<Prose>
			<slot />
		</Prose>
		<slot name="after" />
	</article>
</Layout>
