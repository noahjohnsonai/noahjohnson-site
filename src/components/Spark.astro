---
// 8-point asterisk / spark mark. Inspired by Anthropic's mark but original geometry.
// Sized via the `size` prop in pixels.
interface Props {
	size?: number;
	class?: string;
}
const { size = 24, class: className = '' } = Astro.props;
---

<svg
	xmlns="http://www.w3.org/2000/svg"
	viewBox="0 0 24 24"
	width={size}
	height={size}
	fill="currentColor"
	aria-hidden="true"
	class={className}
>
	{/* Four leaf-like petals at the cardinals + four shorter petals on the diagonals */}
	<path
		d="M12 1.5
		   C12 6 12.5 10 12 11
		   C13 10.5 17 11.5 22.5 12
		   C17 12.5 13 13.5 12 13
		   C12.5 14 12 18 12 22.5
		   C12 18 11.5 14 12 13
		   C11 13.5 7 12.5 1.5 12
		   C7 11.5 11 10.5 12 11
		   C11.5 10 12 6 12 1.5 Z"
	/>
	{/* Diagonal short petals */}
	<path
		d="M5 5 L9.5 9.5 M19 5 L14.5 9.5 M19 19 L14.5 14.5 M5 19 L9.5 14.5"
		stroke="currentColor"
		stroke-width="1.4"
		stroke-linecap="round"
		fill="none"
		opacity="0.85"
	/>
</svg>
