---
// Modal Pagefind search overlay. Triggered by searchbar-trigger and Cmd/Ctrl+K.
// Pagefind loads its UI from /pagefind/pagefind.js (built into dist/pagefind/ by postbuild).
---

<div
	id="search-overlay"
	class="fixed inset-0 z-50 hidden items-start justify-center p-4 pt-24 bg-black/70 backdrop-blur-sm"
	aria-hidden="true"
>
	<div
		class="w-full max-w-2xl bg-bg-elevated border border-border rounded-xl shadow-2xl overflow-hidden flex flex-col max-h-[80vh]"
		role="dialog"
		aria-modal="true"
		aria-label="Search"
	>
		<div class="flex items-center gap-3 px-4 py-3 border-b border-border-soft">
			<svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-fg-muted" aria-hidden="true">
				<path d="M3 7a4 4 0 1 0 8 0 4 4 0 1 0-8 0M13 13l-3-3" />
			</svg>
			<input
				id="search-input"
				type="text"
				class="flex-1 bg-transparent border-0 text-fg placeholder:text-fg-dim text-base focus:outline-none focus:ring-0"
				placeholder="Search posts and projects…"
				autocomplete="off"
				spellcheck="false"
			/>
			<button
				type="button"
				id="search-close"
				class="text-fg-muted hover:text-fg text-xs uppercase tracking-wider border border-border rounded px-2 py-1 bg-transparent cursor-pointer"
				aria-label="Close search"
			>
				ESC
			</button>
		</div>
		<div id="search-results" class="flex-1 overflow-y-auto p-2">
			<p class="text-fg-dim text-sm p-4 text-center">Start typing to search.</p>
		</div>
	</div>
</div>
