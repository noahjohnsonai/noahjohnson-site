---
import type { CollectionEntry } from 'astro:content';
import { formatRelativeDate } from '../lib/data.ts';

interface Props {
	recentEntries?: (CollectionEntry<'posts'> | CollectionEntry<'projects'>)[];
}
const { recentEntries = [] } = Astro.props;
---

{/*
  Search overlay — positioned over the main column only (not full-screen).
  No backdrop blur. Default state shows recent posts / projects.
*/}
<div
	id="search-overlay"
	class="search-overlay fixed top-12 right-0 left-0 lg:left-72 z-40 hidden flex-col items-stretch justify-start p-4 sm:p-6"
	style="bottom: 5rem"
	aria-hidden="true"
>
	<div
		class="w-full max-w-3xl mx-auto bg-bg-elevated border border-border rounded-xl shadow-2xl overflow-hidden flex flex-col max-h-full"
		role="dialog"
		aria-modal="true"
		aria-label="Search"
	>
		<div class="flex items-center gap-3 px-5 py-4 border-b border-border-soft shrink-0">
			<svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-fg-muted" aria-hidden="true">
				<path d="M3 8a5 5 0 1 0 10 0 5 5 0 1 0-10 0M15 15l-3-3" />
			</svg>
			<input
				id="search-input"
				type="text"
				class="flex-1 bg-transparent border-0 text-fg placeholder:text-fg-dim text-lg focus:outline-none focus:ring-0"
				placeholder="Search posts and projects…"
				autocomplete="off"
				spellcheck="false"
			/>
			<button
				type="button"
				id="search-close"
				class="text-fg-muted hover:text-fg text-xs uppercase tracking-wider border border-border rounded px-2 py-1 bg-transparent cursor-pointer"
				aria-label="Close search"
			>
				ESC
			</button>
		</div>
		<div id="search-results" class="flex-1 overflow-y-auto p-2">
			<div id="search-default">
				<p class="text-xs uppercase tracking-wider text-fg-muted font-medium px-4 pt-3 pb-2">Recent</p>
				{
					recentEntries.length === 0 ? (
						<p class="text-fg-dim text-sm p-4 text-center">Nothing here yet.</p>
					) : (
						<ul class="list-none p-0 m-0">
							{recentEntries.map((entry) => {
								const collection = entry.collection;
								const href = `/${collection}/${entry.id}/`;
								return (
									<li>
										<a
											href={href}
											class="block px-4 py-2.5 mx-1 rounded-md hover:bg-surface no-underline"
										>
											<div class="flex items-baseline justify-between gap-3">
												<span class="text-fg font-medium text-sm truncate">
													{entry.data.title}
												</span>
												<span class="text-xs text-fg-dim shrink-0">
													{formatRelativeDate(entry.data.pubDate)}
												</span>
											</div>
											{entry.data.description && (
												<div class="text-fg-muted text-xs mt-0.5 line-clamp-1">
													{entry.data.description}
												</div>
											)}
										</a>
									</li>
								);
							})}
						</ul>
					)
				}
			</div>
			<div id="search-live" class="hidden"></div>
		</div>
	</div>
</div>
