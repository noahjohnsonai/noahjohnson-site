---
interface Crumb {
	label: string;
	href?: string;
}
interface Props {
	breadcrumbs: Crumb[];
}
const { breadcrumbs } = Astro.props;
---

<header class="topbar shrink-0 flex items-center justify-between gap-3 px-4 lg:px-5 h-12 border-b border-border-soft bg-bg z-20">
	<div class="flex items-center gap-2 min-w-0">
		{/* Mobile sidebar toggle */}
		<button
			type="button"
			id="sidebar-toggle"
			class="lg:hidden p-1.5 rounded-md text-fg-muted hover:bg-surface hover:text-fg border-0 bg-transparent cursor-pointer"
			aria-label="Open navigation"
			aria-controls="sidebar"
		>
			<svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
				<path d="M3 5h12M3 9h12M3 13h12" />
			</svg>
		</button>
		<nav class="flex items-center gap-1.5 min-w-0 text-[14px]" aria-label="Breadcrumb">
			{breadcrumbs.map((crumb, i) => (
				<>
					{i > 0 && (
						<span class="text-fg-dim shrink-0" aria-hidden="true">/</span>
					)}
					{crumb.href && i < breadcrumbs.length - 1 ? (
						<a
							href={crumb.href}
							class="text-fg-muted hover:text-fg no-underline truncate"
						>
							{crumb.label}
						</a>
					) : (
						<span class="text-fg truncate">{crumb.label}</span>
					)}
				</>
			))}
		</nav>
	</div>

	<button
		type="button"
		id="rightpanel-toggle"
		class="p-1.5 rounded-md text-fg-muted hover:bg-surface hover:text-fg border-0 bg-transparent cursor-pointer"
		aria-label="Toggle markdown source panel"
		aria-controls="rightpanel"
	>
		<svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
			<rect x="2" y="3" width="14" height="12" rx="1.5" />
			<path d="M11 3v12" />
		</svg>
	</button>
</header>
