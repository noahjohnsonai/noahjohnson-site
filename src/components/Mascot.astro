---
// Mascot: Claude orange pixel bike (no rider, frame + wheels).
// Trimmed to tight bounds so it sits flush above the chat input bar.
import { Image } from 'astro:assets';
import bikeSrc from '../assets/bike.png';

interface Props {
	size?: number; // controls width; height scales to preserve aspect ratio
	class?: string;
	style?: string;
}
const { size = 88, class: className = '', style = '' } = Astro.props;

// bike.png is 1125x944 → aspect ~1.192
const ASPECT = 1125 / 944;
const height = Math.round(size / ASPECT);
---

<Image
	src={bikeSrc}
	alt=""
	width={size}
	height={height}
	loading="lazy"
	decoding="async"
	style={`image-rendering: pixelated; image-rendering: crisp-edges; ${style}`}
	class={className}
/>
