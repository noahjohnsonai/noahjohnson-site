---
// Mascot: the user's claude-bicycle-pixel_v5.png — Claude orange pixel bike.
// Rendered with image-rendering:pixelated to preserve crisp pixel edges
// at any display size. The cream background of the source PNG is preserved
// (looks "right" against our warm-dark site bg). If we ever need a fully
// transparent version, recolor the PNG offline.
import { Image } from 'astro:assets';
import bikeSrc from '../assets/bike.png';

interface Props {
	size?: number;
	class?: string;
}
const { size = 96, class: className = '' } = Astro.props;
---

<Image
	src={bikeSrc}
	alt=""
	width={size}
	height={size}
	loading="lazy"
	decoding="async"
	style="image-rendering: pixelated; image-rendering: crisp-edges;"
	class={className}
/>
