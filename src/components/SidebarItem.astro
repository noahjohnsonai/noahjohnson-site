---
// One sidebar "session" row. Shows status dot + title.
// The status dot has two states, controlled by JS in Layout via the
// `data-visited` attribute on the inner span:
//   - unvisited (default): filled accent-soft circle (Claude Code "needs input")
//   - visited: hollow outline circle (Claude Code "already handled")
// JS sets data-visited="1" once the user has been to a page.
interface Props {
	href: string;
	title: string;
	slug: string; // used as the localStorage key for visited tracking
	meta?: string; // optional right-aligned text (e.g., "2d")
	active?: boolean; // current route
	featured?: boolean;
}
const { href, title, slug, meta, active = false, featured = false } = Astro.props;
---

<li class="list-none">
	<a
		href={href}
		data-slug={slug}
		aria-current={active ? 'page' : undefined}
		class:list={[
			'flex items-center gap-2 px-3 py-1.5 mx-2 rounded-md text-[14px] no-underline transition-colors group',
			active
				? 'bg-surface text-fg font-medium'
				: 'text-fg-muted hover:bg-surface hover:text-fg',
		]}
	>
		<span
			class="sidebar-dot shrink-0 inline-block w-2 h-2 rounded-full transition-colors"
			data-unvisited-dot={slug}
			aria-hidden="true"
		></span>
		<span class="truncate flex-1">{title}</span>
		{
			meta && (
				<span class="shrink-0 text-xs text-fg-dim group-hover:text-fg-muted">
					{meta}
				</span>
			)
		}
		{
			featured && !meta && (
				<span class="shrink-0 text-xs text-accent" aria-label="featured">★</span>
			)
		}
	</a>
</li>

<style is:global>
	/* Two-state status dot, controlled by data-visited (set by Layout JS). */
	.sidebar-dot {
		position: relative;
		background: var(--color-accent-soft);
		border: 1px solid transparent;
	}
	.sidebar-dot[data-visited="1"] {
		background: transparent;
		border-color: var(--color-fg-dim);
	}
	/* "Viewed" pill on hover of the visited-state dot. Matches the
	   ScrollProgress tooltip treatment for visual consistency. */
	.sidebar-dot[data-visited="1"]::after {
		content: "Viewed";
		position: absolute;
		left: 50%;
		bottom: calc(100% + 6px);
		transform: translateX(-50%);
		background: var(--color-bg-elevated);
		border: 1px solid var(--color-border-soft);
		color: var(--color-fg-muted);
		font-size: 10px;
		font-weight: 500;
		padding: 2px 6px;
		border-radius: 4px;
		white-space: nowrap;
		opacity: 0;
		pointer-events: none;
		transition: opacity 120ms ease;
		z-index: 50;
	}
	.sidebar-dot[data-visited="1"]:hover::after {
		opacity: 1;
	}
</style>
