---
// Wraps post body with typography styles matched to Claude Code's reading vibe.
// Tailwind 4 + custom selectors on the rendered HTML.
---

<div class="prose">
	<slot />
</div>

<style>
	.prose {
		max-width: 70ch;
		color: var(--color-fg);
		font-size: 1rem;
		line-height: 1.7;
	}
	.prose :global(h1) {
		font-family: var(--font-sans);
		font-size: 1.875rem;
		font-weight: 600;
		color: var(--color-fg);
		line-height: 1.2;
		margin: 0 0 0.75em;
		letter-spacing: -0.01em;
	}
	.prose :global(h2) {
		font-family: var(--font-sans);
		font-size: 1.375rem;
		font-weight: 600;
		color: var(--color-fg);
		line-height: 1.3;
		margin: 2em 0 0.6em;
		letter-spacing: -0.01em;
	}
	.prose :global(h3) {
		font-family: var(--font-sans);
		font-size: 1.125rem;
		font-weight: 600;
		color: var(--color-fg);
		margin: 1.5em 0 0.5em;
	}
	.prose :global(h4),
	.prose :global(h5),
	.prose :global(h6) {
		font-weight: 600;
		color: var(--color-fg);
		margin: 1.25em 0 0.5em;
	}
	.prose :global(p) {
		margin: 0 0 1.1em;
	}
	.prose :global(a) {
		color: var(--color-accent);
		text-decoration: underline;
		text-underline-offset: 3px;
		text-decoration-color: var(--color-accent-dim);
	}
	.prose :global(a:hover) {
		text-decoration-color: var(--color-accent);
	}
	.prose :global(strong) {
		color: var(--color-fg);
		font-weight: 600;
	}
	.prose :global(em) {
		color: var(--color-fg);
		font-style: italic;
	}
	.prose :global(blockquote) {
		border-left: 3px solid var(--color-accent);
		padding-left: 1em;
		margin: 1.5em 0;
		color: var(--color-fg-muted);
		font-style: normal;
	}
	.prose :global(ul),
	.prose :global(ol) {
		margin: 0 0 1.1em;
		padding-left: 1.5em;
	}
	.prose :global(li) {
		margin: 0.3em 0;
	}
	.prose :global(li::marker) {
		color: var(--color-fg-dim);
	}
	.prose :global(code) {
		font-family: var(--font-mono);
		font-size: 0.875em;
		background: var(--color-surface);
		color: var(--color-fg);
		padding: 0.15em 0.4em;
		border-radius: 4px;
		border: 1px solid var(--color-border-soft);
	}
	.prose :global(pre) {
		font-family: var(--font-mono);
		font-size: 0.85em;
		background: var(--color-bg-elevated);
		border: 1px solid var(--color-border);
		border-radius: 8px;
		padding: 1em 1.2em;
		overflow-x: auto;
		margin: 1.5em 0;
		line-height: 1.6;
	}
	.prose :global(pre code) {
		background: transparent;
		border: none;
		padding: 0;
		font-size: inherit;
	}
	.prose :global(hr) {
		border: none;
		border-top: 1px solid var(--color-border);
		margin: 2em 0;
	}
	.prose :global(img) {
		max-width: 100%;
		height: auto;
		border-radius: 8px;
		margin: 1.5em 0;
	}
	.prose :global(table) {
		border-collapse: collapse;
		width: 100%;
		margin: 1.5em 0;
		font-size: 0.9em;
	}
	.prose :global(th),
	.prose :global(td) {
		text-align: left;
		padding: 0.5em 0.8em;
		border-bottom: 1px solid var(--color-border-soft);
	}
	.prose :global(th) {
		color: var(--color-fg);
		font-weight: 600;
	}
	.prose :global(td) {
		color: var(--color-fg-muted);
	}
</style>
