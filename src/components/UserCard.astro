---
import { AUTHOR, AUTHOR_INITIALS, AUTHOR_DOMAIN, AUTHOR_GITHUB, AUTHOR_LINKEDIN, AUTHOR_EMAIL } from '../consts.ts';
---

<div class="mx-2 my-2 flex items-center gap-2 px-3 py-2.5 rounded-lg border border-transparent hover:border-border transition-colors">
	<a
		href="/about/"
		class="flex items-center gap-3 min-w-0 flex-1 no-underline"
		aria-label="About Noah Johnson"
	>
		<span
			class="flex shrink-0 items-center justify-center w-9 h-9 rounded-full bg-accent text-bg font-medium text-sm select-none"
			aria-hidden="true"
		>
			{AUTHOR_INITIALS}
		</span>
		<span class="flex flex-col min-w-0 leading-tight">
			<span class="text-fg text-[14px] font-medium truncate">{AUTHOR}</span>
			<span class="text-fg-muted text-[12px] truncate">{AUTHOR_DOMAIN}</span>
		</span>
	</a>
	<div class="flex items-center gap-0.5 shrink-0">
		<a
			href={AUTHOR_GITHUB}
			target="_blank"
			rel="noopener"
			aria-label="GitHub"
			class="p-1.5 rounded-md text-fg-muted hover:text-fg hover:bg-surface transition-colors"
		>
			<svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
				<path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0 0 16 8c0-4.42-3.58-8-8-8z"/>
			</svg>
		</a>
		<a
			href={AUTHOR_LINKEDIN}
			target="_blank"
			rel="noopener"
			aria-label="LinkedIn"
			class="p-1.5 rounded-md text-fg-muted hover:text-fg hover:bg-surface transition-colors"
		>
			<svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
				<path d="M13.632 13.635h-2.37V9.922c0-.886-.018-2.025-1.234-2.025-1.235 0-1.424.964-1.424 1.96v3.778h-2.37V6h2.275v1.04h.032c.317-.6 1.091-1.232 2.246-1.232 2.4 0 2.845 1.58 2.845 3.637v4.19zM3.558 4.957a1.376 1.376 0 1 1 0-2.753 1.376 1.376 0 0 1 0 2.753zm1.188 8.678H2.37V6h2.376v7.635zM14.816 0H1.18C.528 0 0 .516 0 1.153v13.694C0 15.484.528 16 1.18 16h13.635c.652 0 1.185-.516 1.185-1.153V1.153C16 .516 15.467 0 14.815 0h.001z"/>
			</svg>
		</a>
		<a
			href={`mailto:${AUTHOR_EMAIL}`}
			aria-label="Email"
			class="p-1.5 rounded-md text-fg-muted hover:text-fg hover:bg-surface transition-colors"
		>
			<svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
				<rect x="2" y="3.5" width="12" height="9" rx="1.5"/>
				<path d="m2.5 4.5 5.5 4 5.5-4"/>
			</svg>
		</a>
	</div>
</div>
