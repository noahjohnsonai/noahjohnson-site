---
// Right panel. Two display modes:
//   1. "source" mode — shows the current page's raw markdown source.
//   2. "example" mode — shows one of the inline-linked /examples/<slug> files
//      from the page body. Clicking an example link in the article swaps the
//      panel to that file (no nav). Source toggle flips back to mode 1.
//
// State (open + width) lives in localStorage and survives navigations/reloads.
// Page-level content (raw source + array of resolved examples) is injected at
// runtime via a hidden <script id="rp-page-data" type="application/json"> the
// Layout JS reads.
interface ExampleRef {
	slug: string;
	title: string;
	filename: string;
	content: string;
	href: string;
}
interface Props {
	rawMarkdown?: string;
	filename?: string;
	examples?: ExampleRef[];
}
const { rawMarkdown = '', filename = '', examples = [] } = Astro.props;
// rawMarkdown / filename are still accepted (passed by PostLayout) but the
// drawer no longer renders the page's own source. The drawer is reserved
// for take-home example files referenced inline in the article body. Pages
// without examples render the empty state.
const hasExamples = examples.length > 0;
const initialFilename = hasExamples ? examples[0].filename : '';
const initialContent = hasExamples ? examples[0].content : '';
const initialDownload = hasExamples ? `/examples/${examples[0].slug}.md` : '';
---

{hasExamples && (
	<script
		type="application/json"
		id="rp-page-data"
		set:html={JSON.stringify({ examples })}
	/>
)}

<div
	id="rightpanel-backdrop"
	class="fixed inset-0 z-40 bg-black/60 opacity-0 pointer-events-none transition-opacity duration-200 lg:hidden"
	aria-hidden="true"
></div>
<aside
	id="rightpanel"
	class="rightpanel shrink-0 flex flex-col bg-bg-elevated border-l border-border-soft overflow-hidden relative"
	style="width: 0; transition: width 200ms cubic-bezier(0.4, 0, 0.2, 1), border-left-width 200ms; border-left-width: 0;"
	aria-label="Markdown source panel"
	transition:persist
>
	<style is:global>
		/* Mobile: render as a fixed overlay that slides from the right. */
		@media (max-width: 1023px) {
			#rightpanel {
				position: fixed !important;
				top: 0 !important;
				right: 0 !important;
				bottom: 0 !important;
				height: 100vh !important;
				width: min(90vw, 380px) !important;
				border-left-width: 1px !important;
				transition: transform 200ms cubic-bezier(0.4, 0, 0.2, 1) !important;
				transform: translateX(100%) !important;
				z-index: 50;
			}
			#rightpanel[data-open="1"] {
				transform: translateX(0) !important;
			}
			#rightpanel-content {
				width: 100% !important;
			}
		}
	</style>
	{/* Resize handle (left edge) — desktop only */}
	<div
		id="rightpanel-resize"
		class="absolute left-0 top-0 bottom-0 w-1 cursor-col-resize hover:bg-accent/40 active:bg-accent/60 transition-colors z-10 group hidden lg:block"
		title="Drag to resize"
	>
		<div class="opacity-0 group-hover:opacity-100 absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 transition-opacity pointer-events-none">
			<svg width="10" height="14" viewBox="0 0 10 14" fill="currentColor" class="text-accent" aria-hidden="true">
				<rect x="2" y="1" width="1.5" height="12" rx="0.5" />
				<rect x="6.5" y="1" width="1.5" height="12" rx="0.5" />
			</svg>
		</div>
	</div>

	<div class="shrink-0 flex flex-col h-full max-lg:!w-[min(90vw,380px)]" id="rightpanel-content" style="width: 320px">
		<div class="flex items-center justify-between gap-2 px-3 h-12 border-b border-border-soft shrink-0">
			<div class="flex items-center gap-2 text-sm min-w-0">
				<svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-fg-muted shrink-0" aria-hidden="true">
					<path d="M3 2h6l3 3v7a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V3a1 1 0 0 1 1-1ZM9 2v3h3" />
				</svg>
				<span id="rp-filename" class="font-mono text-[13px] text-fg-muted truncate">
					{initialFilename}
				</span>
			</div>
			<div class="flex items-center gap-1 shrink-0">
				<a
					id="rp-download"
					href={initialDownload}
					download={hasExamples ? examples[0].filename : ''}
					class="p-1 rounded text-fg-muted hover:bg-surface hover:text-fg no-underline transition-colors"
					style={hasExamples ? '' : 'display: none'}
					aria-label="Download file"
					title="Download .md"
				>
					<svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
						<path d="M7 1v9M3 7l4 4 4-4M2 13h10" />
					</svg>
				</a>
				<button
					type="button"
					id="rightpanel-close"
					class="p-1 rounded text-fg-muted hover:bg-surface hover:text-fg border-0 bg-transparent cursor-pointer"
					aria-label="Close markdown source panel"
				>
					<svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
						<path d="M3 3l8 8M11 3l-8 8" />
					</svg>
				</button>
			</div>
		</div>

		<div id="rp-body" class="flex-1 overflow-auto bg-bg-elevated">
			{hasExamples ? (
				<pre class="m-0 p-4 text-[13px] leading-relaxed font-mono text-fg-muted whitespace-pre-wrap break-words">{initialContent}</pre>
			) : (
				<div class="h-full flex flex-col items-center justify-center px-6 text-center text-fg-dim text-[13px] gap-2">
					<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="opacity-60" aria-hidden="true">
						<path d="M4 6h16M4 10h16M4 14h10M4 18h10" />
					</svg>
					<p class="m-0 leading-relaxed">Nothing to show here.<br/>Articles with take-home files surface them in this drawer.</p>
				</div>
			)}
		</div>
	</div>
</aside>
