---
interface Props {
	rawMarkdown?: string;
	filename?: string;
}
const { rawMarkdown = '', filename = '' } = Astro.props;
const hasContent = rawMarkdown.trim().length > 0;
const displayFilename = filename || 'no-source.md';
---

{/*
  Right panel: always rendered. State (open/closed + width) lives in
  localStorage so it survives navigations and reloads. Drag the left
  edge to resize between 240px and 600px.
*/}
<aside
	id="rightpanel"
	class="rightpanel shrink-0 flex flex-col bg-bg-elevated border-l border-border-soft overflow-hidden relative"
	style="width: 0; transition: width 200ms cubic-bezier(0.4, 0, 0.2, 1), border-left-width 200ms; border-left-width: 0;"
	aria-label="Markdown source panel"
	transition:persist
>
	{/* Resize handle (left edge) */}
	<div
		id="rightpanel-resize"
		class="absolute left-0 top-0 bottom-0 w-1 cursor-col-resize hover:bg-accent/40 active:bg-accent/60 transition-colors z-10 group"
		title="Drag to resize"
	>
		<div class="opacity-0 group-hover:opacity-100 absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 transition-opacity pointer-events-none">
			<svg width="10" height="14" viewBox="0 0 10 14" fill="currentColor" class="text-accent" aria-hidden="true">
				<rect x="2" y="1" width="1.5" height="12" rx="0.5" />
				<rect x="6.5" y="1" width="1.5" height="12" rx="0.5" />
			</svg>
		</div>
	</div>

	<div class="shrink-0 flex flex-col h-full" id="rightpanel-content" style="width: 320px">
		<div class="flex items-center justify-between px-4 h-12 border-b border-border-soft shrink-0">
			<div class="flex items-center gap-2 text-sm min-w-0">
				<svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-fg-muted shrink-0" aria-hidden="true">
					<path d="M3 2h6l3 3v7a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V3a1 1 0 0 1 1-1ZM9 2v3h3" />
				</svg>
				<span class="font-mono text-[13px] text-fg-muted truncate">{displayFilename}</span>
			</div>
			<button
				type="button"
				id="rightpanel-close"
				class="p-1 rounded text-fg-muted hover:bg-surface hover:text-fg border-0 bg-transparent cursor-pointer"
				aria-label="Close markdown source panel"
			>
				<svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
					<path d="M3 3l8 8M11 3l-8 8" />
				</svg>
			</button>
		</div>

		{hasContent ? (
			<pre class="flex-1 overflow-auto p-4 m-0 text-[13px] leading-relaxed font-mono text-fg-muted whitespace-pre-wrap break-words bg-bg-elevated">{rawMarkdown}</pre>
		) : (
			<div class="flex-1 flex flex-col items-center justify-center px-6 text-center text-fg-dim text-[13px] gap-2">
				<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="opacity-60" aria-hidden="true">
					<path d="M4 6h16M4 10h16M4 14h10M4 18h10" />
				</svg>
				<p class="m-0 leading-relaxed">No source for this page.<br/>Open a post or project to see its markdown.</p>
			</div>
		)}
	</div>
</aside>
