---
/**
 * Theme switcher — 4 swatches in the sidebar footer.
 * Brand marks: lobe-icons color variants from /public/brands/.
 */
const themes = [
	{ id: 'claude',      label: 'Claude',      bg: '#1A1A1A' },
	{ id: 'codex',       label: 'Codex',       bg: '#0D0D0D' },
	{ id: 'antigravity', label: 'Antigravity', bg: '#0F1115' },
	{ id: 'cursor',      label: 'Cursor',      bg: '#0A0A0A' },
];
---

<div
	class="theme-switcher mx-2 mb-2 mt-1 px-3 py-2 flex items-center gap-2"
	aria-label="Theme"
>
	<span class="text-[11px] uppercase tracking-wider text-fg-dim mr-1 select-none">
		Theme
	</span>
	<div class="flex items-center gap-1.5" role="radiogroup" aria-label="Choose theme">
		{themes.map((t) => (
			<button
				type="button"
				class="theme-swatch w-6 h-6 rounded-md border border-border hover:scale-110 transition-transform cursor-pointer flex items-center justify-center"
				data-theme-id={t.id}
				role="radio"
				aria-checked="false"
				aria-label={t.label}
				title={t.label}
				style={`background-color: ${t.bg};`}
			>
				<img src={`/brands/${t.id}.svg`} alt="" width="14" height="14" />
			</button>
		))}
	</div>
</div>

<style>
	.theme-swatch[aria-checked="true"] {
		outline: 2px solid var(--color-accent);
		outline-offset: 2px;
	}
</style>

<script>
	const THEMES = ['claude', 'codex', 'antigravity', 'cursor'] as const;
	type Theme = typeof THEMES[number];

	function isTheme(v: string | null): v is Theme {
		return !!v && (THEMES as readonly string[]).includes(v);
	}

	function getCurrent(): Theme {
		const attr = document.documentElement.getAttribute('data-theme');
		return isTheme(attr) ? attr : 'claude';
	}

	function setTheme(theme: Theme) {
		document.documentElement.setAttribute('data-theme', theme);
		try { localStorage.setItem('theme', theme); } catch {}
		syncSwatches();
	}

	function syncSwatches() {
		const current = getCurrent();
		document.querySelectorAll<HTMLButtonElement>('.theme-swatch').forEach((btn) => {
			const id = btn.dataset.themeId;
			btn.setAttribute('aria-checked', id === current ? 'true' : 'false');
		});
	}

	function wire() {
		document.querySelectorAll<HTMLButtonElement>('.theme-swatch').forEach((btn) => {
			if (btn.dataset.wired) return;
			btn.dataset.wired = '1';
			btn.addEventListener('click', () => {
				const id = btn.dataset.themeId;
				if (isTheme(id ?? null)) setTheme(id as Theme);
			});
		});
		syncSwatches();
	}

	wire();
	document.addEventListener('astro:after-swap', wire);
</script>
