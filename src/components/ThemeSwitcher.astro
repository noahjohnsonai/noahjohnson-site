---
import { siClaude, siGooglegemini, siCursor } from 'simple-icons';

/**
 * Theme switcher — 4 swatches in the sidebar footer.
 * Brand marks: Claude/Gemini/Cursor from simple-icons (CC0);
 * Codex from lobe-icons (MIT).
 */
const CODEX_PATH = "M8.086.457a6.105 6.105 0 013.046-.415c1.333.153 2.521.72 3.564 1.7a.117.117 0 00.107.029c1.408-.346 2.762-.224 4.061.366l.063.03.154.076c1.357.703 2.33 1.77 2.918 3.198.278.679.418 1.388.421 2.126a5.655 5.655 0 01-.18 1.631.167.167 0 00.04.155 5.982 5.982 0 011.578 2.891c.385 1.901-.01 3.615-1.183 5.14l-.182.22a6.063 6.063 0 01-2.934 1.851.162.162 0 00-.108.102c-.255.736-.511 1.364-.987 1.992-1.199 1.582-2.962 2.462-4.948 2.451-1.583-.008-2.986-.587-4.21-1.736a.145.145 0 00-.14-.032c-.518.167-1.04.191-1.604.185a5.924 5.924 0 01-2.595-.622 6.058 6.058 0 01-2.146-1.781c-.203-.269-.404-.522-.551-.821a7.74 7.74 0 01-.495-1.283 6.11 6.11 0 01-.017-3.064.166.166 0 00.008-.074.115.115 0 00-.037-.064 5.958 5.958 0 01-1.38-2.202 5.196 5.196 0 01-.333-1.589 6.915 6.915 0 01.188-2.132c.45-1.484 1.309-2.648 2.577-3.493.282-.188.55-.334.802-.438.286-.12.573-.22.861-.304a.129.129 0 00.087-.087A6.016 6.016 0 015.635 2.31C6.315 1.464 7.132.846 8.086.457zm-.804 7.85a.848.848 0 00-1.473.842l1.694 2.965-1.688 2.848a.849.849 0 001.46.864l1.94-3.272a.849.849 0 00.007-.854l-1.94-3.393zm5.446 6.24a.849.849 0 000 1.695h4.848a.849.849 0 000-1.696h-4.848z";

const themes = [
	{ id: 'claude',      label: 'Claude',      accent: '#D97757', bg: '#1A1A1A', path: siClaude.path },
	{ id: 'codex',       label: 'Codex',       accent: '#10A37F', bg: '#0D0D0D', path: CODEX_PATH },
	{ id: 'antigravity', label: 'Antigravity', accent: '#8AB4F8', bg: '#0F1115', path: siGooglegemini.path },
	{ id: 'cursor',      label: 'Cursor',      accent: '#FFFFFF', bg: '#0A0A0A', path: siCursor.path },
];
---

<div
	class="theme-switcher mx-2 mb-2 mt-1 px-3 py-2 flex items-center gap-2"
	aria-label="Theme"
>
	<span class="text-[11px] uppercase tracking-wider text-fg-dim mr-1 select-none">
		Theme
	</span>
	<div class="flex items-center gap-1.5" role="radiogroup" aria-label="Choose theme">
		{themes.map((t) => (
			<button
				type="button"
				class="theme-swatch w-6 h-6 rounded-md border border-border hover:scale-110 transition-transform cursor-pointer flex items-center justify-center"
				data-theme-id={t.id}
				role="radio"
				aria-checked="false"
				aria-label={t.label}
				title={t.label}
				style={`background-color: ${t.bg}; color: ${t.accent};`}
			>
				<svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" fill-rule="evenodd" clip-rule="evenodd" aria-hidden="true">
					<path d={t.path} />
				</svg>
			</button>
		))}
	</div>
</div>

<style>
	.theme-swatch[aria-checked="true"] {
		outline: 2px solid var(--color-accent);
		outline-offset: 2px;
	}
</style>

<script>
	const THEMES = ['claude', 'codex', 'antigravity', 'cursor'] as const;
	type Theme = typeof THEMES[number];

	function isTheme(v: string | null): v is Theme {
		return !!v && (THEMES as readonly string[]).includes(v);
	}

	function getCurrent(): Theme {
		const attr = document.documentElement.getAttribute('data-theme');
		return isTheme(attr) ? attr : 'claude';
	}

	function setTheme(theme: Theme) {
		document.documentElement.setAttribute('data-theme', theme);
		try { localStorage.setItem('theme', theme); } catch {}
		syncSwatches();
	}

	function syncSwatches() {
		const current = getCurrent();
		document.querySelectorAll<HTMLButtonElement>('.theme-swatch').forEach((btn) => {
			const id = btn.dataset.themeId;
			btn.setAttribute('aria-checked', id === current ? 'true' : 'false');
		});
	}

	function wire() {
		document.querySelectorAll<HTMLButtonElement>('.theme-swatch').forEach((btn) => {
			if (btn.dataset.wired) return;
			btn.dataset.wired = '1';
			btn.addEventListener('click', () => {
				const id = btn.dataset.themeId;
				if (isTheme(id ?? null)) setTheme(id as Theme);
			});
		});
		syncSwatches();
	}

	wire();
	document.addEventListener('astro:after-swap', wire);
</script>
